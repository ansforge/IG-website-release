          <valueString value="Observations cliniques : ; Recommandations pour les jours à venir : ; Prochaine visite : 15 avril 2023, 10h30 ; Remarque : Monsieur Dupont a compris les consignes pour la gestion de sa douleur et la mobilisation de sa hanche opérée."/>
        </extension>
        <extension url="https://interop.esante.gouv.fr/ig/fhir/tddui/StructureDefinition/tddui-comment">
          <valueString value="Cet évènement a débuté plus tard l’usager était sous la douche à l’heure du début du rendez-vous."/>
        </extension>
        <extension url="https://interop.esante.gouv.fr/ig/fhir/tddui/StructureDefinition/tddui-event-label">
          <valueString value="Visite à domicile pour soins infirmier."/>
        </extension>
        <extension url="https://interop.esante.gouv.fr/ig/fhir/tddui/StructureDefinition/tddui-event-reason">
          <valueString value="Suivi post-opératoire suite à intervention chirurgicale de la hanche."/>
        </extension>
        <extension url="https://interop.esante.gouv.fr/ig/fhir/tddui/StructureDefinition/tddui-patient-validation">
          <valueBoolean value="true"/>
        </extension>
        <identifier>
          <type>
            <coding>
              <system value="https://hl7.fr/ig/fhir/core/CodeSystem/fr-core-cs-identifier-type"/>
              <code value="VN"/>
            </coding>
          </type>
