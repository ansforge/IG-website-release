          <code value="HH"/>
        </class>
        <type>
          <coding>
            <system value="https://smt.esante.gouv.fr/fhir/CodeSystem/terminologie-cisis"/>
            <code value="MED-1298"/>
            <display value="Intervention d'un infirmer salarié"/>
          </coding>
        </type>
        <type>
