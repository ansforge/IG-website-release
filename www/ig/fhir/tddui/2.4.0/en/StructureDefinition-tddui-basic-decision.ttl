     fhir:StructureDefinition.snapshot.element [
       fhir:index -1 ;
       fhir:Element.id [ fhir:value "Basic" ] ;
       fhir:ElementDefinition.path [ fhir:value "Basic" ] ;
       fhir:ElementDefinition.short [ fhir:value "Resource for non-supported content" ] ;
       fhir:ElementDefinition.definition [ fhir:value "Basic is used for handling concepts not yet defined in FHIR, narrative-only resources that don't map to an existing resource, and custom resources not appropriate for inclusion in the FHIR specification." ] ;
       fhir:ElementDefinition.alias [
