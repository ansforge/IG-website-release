  <url value="https://interop.esante.gouv.fr/ig/fhir/cdl/CapabilityStatement/ConsommateurContenu"/>
  <version value="3.0.1"/>
  <name value="ConsommateurContenu"/>
  <title value="CI-SIS Cahier-de-Liaison - ConsommateurContenu"/>
  <status value="active"/>
  <experimental value="false"/>
  <date value="2023-02-15T14:22:09+01:00"/>
  <publisher value="ANS"/>
  <contact>
    <name value="ANS"/>
    <telecom>
      <system value="url"/>
      <value value="https://esante.gouv.fr"/>
    </telecom>
  </contact>
  <description value="Le consommateur de contenu qui interroge le cahier de liaison"/>
  <jurisdiction>
    <coding>
      <system value="urn:iso:std:iso:3166"/>
      <code value="FR"/>
      <display value="France (la)"/>
    </coding>
  </jurisdiction>
  <kind value="requirements"/>
  <fhirVersion value="4.0.1"/>
  <format value="application/fhir+xml"/>
  <format value="application/fhir+json"/>
  <implementationGuide value="http://interop.esante.gouv.fr/ig/fhir/cdl/ImplementationGuides/ans.fhir.fr.cdl"/>
  <rest>
    <mode value="client"/>
    <documentation value="Le consommateur de contenu envoie une demande de recherche de notes au gestionnaire de CdL"/>
    <security>
      <cors value="false"/>
      <description value="L’ANS propose des référentiels dédiés à la politique de sécurité (la PGSSI-S&#xA;) et des mécanismes de sécurisation sont définis dans les volets de la couche Transport du Cadre d’Interopérabilité des systèmes&#xA;d’information de santé (CI-SIS)"/>
    </security>
    <resource>
      <type value="DocumentReference"/>
      <profile value="https://interop.esante.gouv.fr/ig/fhir/cdl/StructureDefinition/cdl-document-reference|3.0.1"/>
      <interaction>
        <code value="read"/>
      </interaction>
      <interaction>
        <code value="search-type"/>
      </interaction>
      <searchParam>
        <name value="date"/>
        <definition value="http://hl7.org/fhir/SearchParameter/DocumentReference-date|4.0.1"/>
        <type value="date"/>
        <documentation value="date de création de la note"/>
      </searchParam>
      <searchParam>
        <name value="type"/>
        <definition value="http://hl7.org/fhir/SearchParameter/clinical-type|4.0.1"/>
        <type value="token"/>
        <documentation value="type de la note"/>
      </searchParam>
      <searchParam>
        <name value="security-label"/>
        <definition value="http://hl7.org/fhir/SearchParameter/DocumentReference-security-label|4.0.1"/>
        <type value="token"/>
        <documentation value="degré de restriction de l'audience de la note"/>
      </searchParam>
      <searchParam>
        <name value="subject"/>
        <definition value="http://hl7.org/fhir/SearchParameter/DocumentReference-subject|4.0.1"/>
        <type value="reference"/>
        <documentation value="Sujet de la note"/>
      </searchParam>
      <searchParam>
        <name value="author"/>
        <definition value="http://hl7.org/fhir/SearchParameter/DocumentReference-author|4.0.1"/>
        <type value="reference"/>
        <documentation value="Sujet de la note"/>
      </searchParam>
    </resource>
    <resource>
      <type value="Patient"/>
      <profile value="https://hl7.fr/ig/fhir/core/StructureDefinition/fr-core-patient|2.0.1"/>
      <interaction>
        <code value="read"/>
      </interaction>
      <interaction>
        <code value="search-type"/>
      </interaction>
      <searchParam>
        <name value="identifier"/>
        <definition value="http://hl7.org/fhir/SearchParameter/Patient-identifier|4.0.1"/>
        <type value="token"/>
        <documentation value="Identifiant du patient"/>
      </searchParam>
      <searchParam>
        <name value="family"/>
        <definition value="http://hl7.org/fhir/SearchParameter/individual-family|4.0.1"/>
        <type value="string"/>
        <documentation value="Nom de famille du patient"/>
      </searchParam>
      <searchParam>
        <name value="given"/>
        <definition value="http://hl7.org/fhir/SearchParameter/individual-given|4.0.1"/>
        <type value="string"/>
        <documentation value="Prénom du patient"/>
      </searchParam>
      <searchParam>
        <name value="name"/>
        <definition value="http://hl7.org/fhir/SearchParameter/Patient-name|4.0.1"/>
        <type value="string"/>
        <documentation value="Nom du patient"/>
      </searchParam>
    </resource>
    <resource>
      <type value="RelatedPerson"/>
      <profile value="https://hl7.fr/ig/fhir/core/StructureDefinition/fr-core-patient|2.0.1"/>
      <interaction>
        <code value="read"/>
      </interaction>
      <interaction>
        <code value="search-type"/>
      </interaction>
      <searchParam>
        <name value="identifier"/>
        <definition value="http://hl7.org/fhir/SearchParameter/RelatedPerson-identifier|4.0.1"/>
        <type value="token"/>
        <documentation value="Identifiant de la personne de confiance"/>
      </searchParam>
      <searchParam>
        <name value="name"/>
        <definition value="http://hl7.org/fhir/SearchParameter/RelatedPerson-name|4.0.1"/>
        <type value="string"/>
        <documentation value="Nom de la personne de confiance"/>
      </searchParam>
    </resource>
    <resource>
      <type value="Practitioner"/>
      <profile value="https://interop.esante.gouv.fr/ig/fhir/annuaire/StructureDefinition/as-practitioner|1.0.1"/>
      <interaction>
        <code value="read"/>
      </interaction>
      <interaction>
        <code value="search-type"/>
      </interaction>
      <searchParam>
        <name value="identifier"/>
        <definition value="http://hl7.org/fhir/SearchParameter/Practitioner-identifier|4.0.1"/>
        <type value="token"/>
        <documentation value="Identifiant du Praticien"/>
      </searchParam>
      <searchParam>
        <name value="family"/>
        <definition value="http://hl7.org/fhir/SearchParameter/individual-family|4.0.1"/>
        <type value="string"/>
        <documentation value="Nom de famille du patient"/>
      </searchParam>
      <searchParam>
        <name value="given"/>
        <definition value="http://hl7.org/fhir/SearchParameter/individual-given|4.0.1"/>
        <type value="string"/>
        <documentation value="Prénom du patient"/>
      </searchParam>
      <searchParam>
        <name value="name"/>
        <definition value="http://hl7.org/fhir/SearchParameter/Practitioner-name|4.0.1"/>
        <type value="string"/>
        <documentation value="Nom du patient"/>
      </searchParam>
    </resource>
    <resource>
      <type value="Organization"/>
      <profile value="https://interop.esante.gouv.fr/ig/fhir/annuaire/StructureDefinition/as-organization|1.0.1"/>
      <interaction>
        <code value="read"/>
      </interaction>
      <interaction>
        <code value="search-type"/>
      </interaction>
      <searchParam>
        <name value="identifier"/>
        <definition value="http://hl7.org/fhir/SearchParameter/Organization-identifier|4.0.1"/>
        <type value="token"/>
        <documentation value="Identifiant de l'organisation"/>
      </searchParam>
    </resource>
    <resource>
      <type value="Device"/>
      <profile value="http://hl7.org/fhir/StructureDefinition/Device|4.0.1"/>
      <interaction>
        <code value="read"/>
      </interaction>
      <interaction>
        <code value="search-type"/>
      </interaction>
      <searchParam>
        <name value="identifier"/>
        <definition value="http://hl7.org/fhir/SearchParameter/Device-identifier|4.0.1"/>
        <type value="token"/>
        <documentation value="Identifiant de l'équipement"/>
      </searchParam>
    </resource>
  </rest>
</CapabilityStatement>