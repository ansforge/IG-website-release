<https://interop.esante.gouv.fr/ig/fhir/sdo/CapabilityStatement/gestionnaire-sdo> a fhir:CapabilityStatement ;
  fhir:nodeRole fhir:treeRoot ;
  fhir:Resource.id [ fhir:value "gestionnaire-sdo"] ;
